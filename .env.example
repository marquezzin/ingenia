# ─── Django ───────────────────────────────────────────────────────────────────
DJANGO_SECRET_KEY=change-me-in-production-use-a-long-random-string
DJANGO_SETTINGS_MODULE=config.settings.local
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# ─── Database (Postgres 18) ────────────────────────────────────────────────────
DATABASE_URL=postgres://ingenia_user:ingenia_pass@db:5432/ingenia_db
POSTGRES_DB=ingenia_db
POSTGRES_USER=ingenia_user
POSTGRES_PASSWORD=ingenia_pass

# ─── Redis ────────────────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0

# ─── JWT ──────────────────────────────────────────────────────────────────────
JWT_ACCESS_TOKEN_LIFETIME_MINUTES=60
JWT_REFRESH_TOKEN_LIFETIME_DAYS=7

# ─── CORS & CSRF ────────────────────────────────────────────────────────────────
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
CSRF_TRUSTED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# ─── Frontend ─────────────────────────────────────────────────────────────────
VITE_API_BASE_URL=http://localhost:8000
# Em prod, restrinja os hosts aceitos pelo dev server do Vite (ex.: ingenia.synaptha.com).
# Em dev, deixe vazio para liberar todos os hosts.
VITE_ALLOWED_HOSTS=

# ─── Email (SMTP) ─────────────────────────────────────────────────────────────
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.hostinger.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_USE_SSL=False
EMAIL_HOST_USER=no-reply@seudominio.com
EMAIL_HOST_PASSWORD=
DEFAULT_FROM_EMAIL="Ingenia <no-reply@seudominio.com>"

# ─── Módulos Opcionais ─────────────────────────────────────────────────────────
MODULE_AI_ENABLED=true
VITE_MODULE_AI_ENABLED=true
# MODULE_DASHBOARD_ENABLED=false
# VITE_MODULE_DASHBOARD_ENABLED=false
# MODULE_ASAAS_ENABLED=false
# VITE_MODULE_INTEGRATIONS_ENABLED=false
